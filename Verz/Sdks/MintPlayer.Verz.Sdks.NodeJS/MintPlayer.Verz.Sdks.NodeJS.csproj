<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>MintPlayer.Verz.Sdks.NodeJS</RootNamespace>
		<Version>0.0.0-placeholder</Version>
		<Description>Verz IDevelopmentSdk plugin for NodeJS workspaces. Discovers npm/yarn/pnpm/Nx workspace members, stamps package.json versions, packs npm tarballs, hashes .d.ts surfaces.</Description>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\MintPlayer.Verz.Abstractions\MintPlayer.Verz.Abstractions.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
		<PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" Version="9.0.0" />
		<PackageReference Include="YamlDotNet" Version="16.2.1" />
	</ItemGroup>

</Project>
