<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>MintPlayer.Verz.Registries.GithubPackageRegistry</RootNamespace>
		<Version>0.0.0-placeholder</Version>
		<Description>Verz IPackageRegistry plugin for GitHub Packages NuGet feeds (nuget.pkg.github.com). Specialised over the generic NugetOrg plugin to claim per-org GitHub URLs and tolerate auth quirks.</Description>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\MintPlayer.Verz.Abstractions\MintPlayer.Verz.Abstractions.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
		<PackageReference Include="NuGet.Protocol" Version="6.10.1" />
	</ItemGroup>

</Project>
