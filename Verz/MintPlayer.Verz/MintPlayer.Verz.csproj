<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<LangVersion>14</LangVersion>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>MintPlayer.Verz</RootNamespace>
		<Version>0.0.0-placeholder</Version>

		<IsPackable>true</IsPackable>
		<PackAsTool>true</PackAsTool>
		<ToolCommandName>verz</ToolCommandName>
		<PackageId>MintPlayer.Verz</PackageId>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<Description>A .NET global tool that derives library versions from git tags and publishes packages to NuGet, npm, and GitHub Packages via a plugin model.</Description>
	</PropertyGroup>

	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Hosting" Version="9.0.0" />
		<PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
		<PackageReference Include="NuGet.Protocol" Version="6.10.1" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\MintPlayer.Verz.Abstractions\MintPlayer.Verz.Abstractions.csproj" />
	</ItemGroup>

</Project>
